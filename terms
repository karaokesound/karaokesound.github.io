            font-size: 20px;
            font-weight: 700;
            color: #FDFCF9;
            margin-bottom: 16px;
            padding-bottom: 12px;
            border-bottom: 1px solid rgba(253,252,249,0.15);
        }

        .card p {
            font-size: 15px;
            font-weight: 300;
            line-height: 1.75;
            color: rgba(253,252,249,0.82);
            margin-bottom: 12px;
        }
        .card p:last-child {
            margin-bottom: 0;
        }

        .card ul {
            list-style: none;
            padding: 0;
            margin: 0 0 12px 0;
        }
        .card ul li {
            font-size: 15px;
            font-weight: 300;
            line-height: 1.7;
            color: rgba(253,252,249,0.82);
            padding: 4px 0 4px 20px;
            position: relative;
        }
        .card ul li::before {
            content: '';
            position: absolute;
            left: 0;
            top: 13px;
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: rgba(253,252,249,0.4);
        }

        .card a {
            color: rgba(253,252,249,0.9);
            text-decoration: none;
            border-bottom: 1px solid rgba(253,252,249,0.35);
            transition: border-color 0.2s;
        }
        .card a:hover {
            border-color: rgba(253,252,249,0.8);
        }

